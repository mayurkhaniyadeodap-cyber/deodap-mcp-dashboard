# --- DeoDap MCP Dashboard · Backend env (example) ---
# Copy to .env (local) or .env.production (deploy) and fill in. Never commit real values.

# Set to "production" in the deployed environment. This enables fail-fast guards:
# the app refuses to boot with the dev JWT secret or with ENABLE_MCP_DEBUG=true.
ENVIRONMENT=development

# JWT signing secret — REQUIRED in production. Generate fresh, never reuse:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=480

# First-admin seed — only used the first time the users table is empty. Set a
# strong password; if blank, a random one is generated and printed to the log once.
ADMIN_EMAIL=admin@deodap.in
ADMIN_PASSWORD=

# User store. SQLite by default; in the container use the mounted volume:
#   DATABASE_URL=sqlite:////data/deodap.db   (four slashes = absolute path)
DATABASE_URL=sqlite:///./deodap.db

# Allowed CORS origins (comma-separated). Dev = the Vite server. Production is
# same-origin (frontend served by FastAPI), so set the deployed origin — never "*".
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ship MCP server. Token is read at runtime, masked in logs, never baked into the image.
MCP_URL=
MCP_TOKEN=
MCP_TIMEOUT_SECONDS=30

# Expose /_mcp/tools and /_mcp/probe (arbitrary MCP tool-call proxy). Local dev only.
# MUST stay false in production (enforced at boot).
ENABLE_MCP_DEBUG=false
